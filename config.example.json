{
  "providers": {
    "github_copilot": {}
  },
  "agents": {
    "defaults": {
      "model": "github_copilot/gpt-4.1",
      "provider": "github_copilot",
      "workspace": "./workspace"
    }
  },
  "gateway": {
    "heartbeat": {
      "enabled": true,
      "interval_s": 3600
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "token": "YOUR_BOT_TOKEN",
      "allowFrom": ["YOUR_TELEGRAM_USER_ID"]
    }
  },
  "tools": {
    "web": {
      "search": {
        "apiKey": "YOUR_BRAVE_SEARCH_API_KEY"
      }
    }
  },
  "stt": {
    "provider": "groq_with_fallback",
    "groq": {
      "apiKey": "YOUR_GROQ_API_KEY"
    },
    "whisper": {
      "model": "base"
    }
  },
  "tts": {
    "provider": "edge_with_fallback",
    "voice": "de-DE-ConradNeural",
    "piper": {
      "model": "de_DE-thorsten-high"
    }
  }
}
